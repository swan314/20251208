# 프론트엔드 (Vite — 브라우저에 노출됨)
# mock: 예시 코칭 | live: /api/coaching 프록시 호출
VITE_AI_COACHING_MODE=mock

# 선택: API 경로 변경 시
# VITE_AI_COACHING_API_PATH=/api/coaching

# 서버 전용 (Netlify Functions — 브라우저에 노출되지 않음)
# 로컬: netlify dev 실행 시 .env에서 읽음
# 배포: Netlify Site settings → Environment variables
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
